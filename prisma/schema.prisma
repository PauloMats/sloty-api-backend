generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OWNER
  STAFF
  CLIENT
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
}

enum BusinessMode {
  SCHEDULED_SERVICE
  ON_DEMAND_REQUEST
  DELIVERY_ORDER
  HYBRID
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ServiceRequestStatus {
  OPEN
  IN_NEGOTIATION
  ACCEPTED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum ServiceProposalStatus {
  SENT
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ConversationStatus {
  OPEN
  ARCHIVED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
  REJECTED
}

enum FulfillmentType {
  DELIVERY
  PICKUP
}

enum AppointmentEventType {
  CREATED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  REMINDER_SCHEDULED
  REMINDER_SENT
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum PaymentType {
  SAAS_SUBSCRIPTION
  APPOINTMENT_PREPAYMENT
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum WebhookProvider {
  STRIPE
  RESEND
}

model User {
  id                  String             @id @default(cuid())
  name                String
  email               String             @unique
  passwordHash        String
  phone               String?
  role                UserRole
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  refreshTokens       RefreshToken[]
  ownedBusinesses     Business[]         @relation("BusinessOwner")
  businessMemberships BusinessMember[]
  clientAppointments  Appointment[]      @relation("AppointmentClient")
  staffAppointments   Appointment[]      @relation("AppointmentStaff")
  serviceRequests     ServiceRequest[]
  conversations       Conversation[]     @relation("ConversationClient")
  messages            Message[]          @relation("MessageSender")
  orders              Order[]
  appointmentEvents   AppointmentEvent[]
  notifications       Notification[]
  emailLogs           EmailLog[]
  addresses           UserAddress[]
}

model UserAddress {
  id            String           @id @default(cuid())
  userId        String
  label         String
  recipientName String?
  phone         String?
  addressLine1  String
  addressLine2  String?
  neighborhood  String?
  city          String
  state         String?
  zipCode       String?
  country       String           @default("BR")
  latitude      Float?
  longitude     Float?
  isDefault     Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests      ServiceRequest[]
  orders        Order[]

  @@index([userId])
  @@index([city])
}

model Category {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  icon        String?
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  businesses  Business[]
  requests    ServiceRequest[]

  @@index([isActive, sortOrder])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Business {
  id                  String                   @id @default(cuid())
  ownerId             String
  categoryId          String?
  mode                BusinessMode             @default(SCHEDULED_SERVICE)
  name                String
  slug                String                   @unique
  description         String?
  category            String?
  phone               String?
  email               String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  zipCode             String?
  country             String?
  latitude            Float?
  longitude           Float?
  timezone            String
  status              BusinessStatus           @default(PENDING_REVIEW)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  owner               User                     @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  categoryRef         Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  members             BusinessMember[]
  services            Service[]
  weeklyAvailability  WeeklyAvailability[]
  closures            BusinessClosure[]
  appointments        Appointment[]
  serviceProposals    ServiceRequestProposal[]
  conversations       Conversation[]
  menuItems           MenuItem[]
  orders              Order[]
  emailLogs           EmailLog[]
  billingCustomer     BillingCustomer?
  billingSubscription BillingSubscription?
  paymentRecords      PaymentRecord[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([city])
  @@index([latitude, longitude])
}

model ServiceRequest {
  id                 String                   @id @default(cuid())
  clientId           String
  categoryId         String?
  addressId          String?
  title              String
  description        String
  city               String
  state              String?
  latitude           Float?
  longitude          Float?
  budgetMinCents     Int?
  budgetMaxCents     Int?
  currency           String                   @default("BRL")
  status             ServiceRequestStatus     @default(OPEN)
  acceptedProposalId String?
  expiresAt          DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  client             User                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category           Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  address            UserAddress?             @relation(fields: [addressId], references: [id], onDelete: SetNull)
  proposals          ServiceRequestProposal[]
  conversations      Conversation[]

  @@index([clientId, createdAt])
  @@index([categoryId])
  @@index([city, status])
  @@index([status, createdAt])
}

model ServiceRequestProposal {
  id                       String                @id @default(cuid())
  requestId                String
  businessId               String
  message                  String
  estimatedPriceCents      Int?
  estimatedDurationMinutes Int?
  status                   ServiceProposalStatus @default(SENT)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  request                  ServiceRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  business                 Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([requestId, businessId])
  @@index([businessId, createdAt])
}

model Conversation {
  id               String             @id @default(cuid())
  clientId         String
  businessId       String
  appointmentId    String?
  serviceRequestId String?
  status           ConversationStatus @default(OPEN)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  client           User               @relation("ConversationClient", fields: [clientId], references: [id], onDelete: Cascade)
  business         Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment      Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  serviceRequest   ServiceRequest?    @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  messages         Message[]

  @@index([clientId, updatedAt])
  @@index([businessId, updatedAt])
  @@index([appointmentId])
  @@index([serviceRequestId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model BusinessMember {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  role       UserRole
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
}

model Service {
  id                  String        @id @default(cuid())
  businessId          String
  name                String
  description         String?
  durationMinutes     Int
  priceCents          Int
  currency            String        @default("BRL")
  bufferBeforeMinutes Int           @default(0)
  bufferAfterMinutes  Int           @default(0)
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  business            Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments        Appointment[]

  @@index([businessId])
}

model MenuItem {
  id          String      @id @default(cuid())
  businessId  String
  name        String
  description String?
  priceCents  Int
  currency    String      @default("BRL")
  imageUrl    String?
  isAvailable Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([businessId, isAvailable, sortOrder])
}

model Order {
  id               String          @id @default(cuid())
  businessId       String
  clientId         String
  addressId        String?
  status           OrderStatus     @default(PENDING)
  fulfillmentType  FulfillmentType @default(DELIVERY)
  subtotalCents    Int
  deliveryFeeCents Int             @default(0)
  totalCents       Int
  currency         String          @default("BRL")
  notes            String?
  acceptedAt       DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  business         Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client           User            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  address          UserAddress?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  items            OrderItem[]

  @@index([businessId, status, createdAt])
  @@index([clientId, createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  menuItemId     String
  nameSnapshot   String
  unitPriceCents Int
  quantity       Int
  notes          String?
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem       MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuItemId])
}

model WeeklyAvailability {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dayOfWeek])
}

model BusinessClosure {
  id         String   @id @default(cuid())
  businessId String
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, startsAt, endsAt])
}

model Appointment {
  id                 String             @id @default(cuid())
  businessId         String
  serviceId          String
  clientId           String
  staffUserId        String?
  startAt            DateTime
  endAt              DateTime
  status             AppointmentStatus  @default(PENDING)
  notes              String?
  source             String             @default("api")
  cancellationReason String?
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  completedAt        DateTime?
  noShowAt           DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  business           Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service            Service            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client             User               @relation("AppointmentClient", fields: [clientId], references: [id], onDelete: Restrict)
  staffUser          User?              @relation("AppointmentStaff", fields: [staffUserId], references: [id], onDelete: SetNull)
  events             AppointmentEvent[]
  emailLogs          EmailLog[]
  paymentRecords     PaymentRecord[]
  conversations      Conversation[]

  @@index([businessId, startAt])
  @@index([clientId, startAt])
  @@index([status])
}

model AppointmentEvent {
  id            String               @id @default(cuid())
  appointmentId String
  type          AppointmentEventType
  actorUserId   String?
  payload       Json
  createdAt     DateTime             @default(now())
  appointment   Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actorUser     User?                @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  template  String
  status    NotificationStatus  @default(PENDING)
  payload   Json
  sentAt    DateTime?
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailLog {
  id            String       @id @default(cuid())
  businessId    String?
  userId        String?
  appointmentId String?
  resendEmailId String?
  template      String
  toEmail       String
  subject       String
  status        String
  errorMessage  String?
  createdAt     DateTime     @default(now())
  business      Business?    @relation(fields: [businessId], references: [id], onDelete: SetNull)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([userId])
  @@index([appointmentId])
}

model BillingCustomer {
  id               String   @id @default(cuid())
  businessId       String   @unique
  stripeCustomerId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BillingSubscription {
  id                   String    @id @default(cuid())
  businessId           String    @unique
  stripeSubscriptionId String
  stripePriceId        String
  status               String
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  business             Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model PaymentRecord {
  id                      String        @id @default(cuid())
  businessId              String
  appointmentId           String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  amountCents             Int
  currency                String
  type                    PaymentType
  status                  PaymentStatus @default(PENDING)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  business                Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment             Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([appointmentId])
}

model WebhookEvent {
  id              String          @id @default(cuid())
  provider        WebhookProvider
  externalEventId String
  type            String
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@unique([provider, externalEventId])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String
  scope        String
  requestHash  String
  responseCode Int?
  responseBody Json?
  createdAt    DateTime @default(now())

  @@unique([scope, key])
}
