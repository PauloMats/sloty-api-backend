generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OWNER
  STAFF
  CLIENT
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentEventType {
  CREATED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  REMINDER_SCHEDULED
  REMINDER_SENT
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum PaymentType {
  SAAS_SUBSCRIPTION
  APPOINTMENT_PREPAYMENT
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum WebhookProvider {
  STRIPE
  RESEND
}

model User {
  id                    String             @id @default(cuid())
  name                  String
  email                 String             @unique
  passwordHash          String
  phone                 String?
  role                  UserRole
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  refreshTokens         RefreshToken[]
  ownedBusinesses       Business[]         @relation("BusinessOwner")
  businessMemberships   BusinessMember[]
  clientAppointments    Appointment[]      @relation("AppointmentClient")
  staffAppointments     Appointment[]      @relation("AppointmentStaff")
  appointmentEvents     AppointmentEvent[]
  notifications         Notification[]
  emailLogs             EmailLog[]
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Business {
  id                   String                 @id @default(cuid())
  ownerId              String
  name                 String
  slug                 String                 @unique
  description          String?
  category             String?
  phone                String?
  email                String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  state                String?
  zipCode              String?
  country              String?
  latitude             Float?
  longitude            Float?
  timezone             String
  status               BusinessStatus         @default(PENDING_REVIEW)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  owner                User                   @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members              BusinessMember[]
  services             Service[]
  weeklyAvailability   WeeklyAvailability[]
  closures             BusinessClosure[]
  appointments         Appointment[]
  emailLogs            EmailLog[]
  billingCustomer      BillingCustomer?
  billingSubscription  BillingSubscription?
  paymentRecords       PaymentRecord[]

  @@index([ownerId])
}

model BusinessMember {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  role       UserRole
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
}

model Service {
  id                  String   @id @default(cuid())
  businessId          String
  name                String
  description         String?
  durationMinutes     Int
  priceCents          Int
  currency            String   @default("BRL")
  bufferBeforeMinutes Int      @default(0)
  bufferAfterMinutes  Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments        Appointment[]

  @@index([businessId])
}

model WeeklyAvailability {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dayOfWeek])
}

model BusinessClosure {
  id         String   @id @default(cuid())
  businessId String
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, startsAt, endsAt])
}

model Appointment {
  id                 String             @id @default(cuid())
  businessId         String
  serviceId          String
  clientId           String
  staffUserId        String?
  startAt            DateTime
  endAt              DateTime
  status             AppointmentStatus  @default(PENDING)
  notes              String?
  source             String             @default("api")
  cancellationReason String?
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  completedAt        DateTime?
  noShowAt           DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  business           Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service            Service            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client             User               @relation("AppointmentClient", fields: [clientId], references: [id], onDelete: Restrict)
  staffUser          User?              @relation("AppointmentStaff", fields: [staffUserId], references: [id], onDelete: SetNull)
  events             AppointmentEvent[]
  emailLogs          EmailLog[]
  paymentRecords     PaymentRecord[]

  @@index([businessId, startAt])
  @@index([clientId, startAt])
  @@index([status])
}

model AppointmentEvent {
  id            String               @id @default(cuid())
  appointmentId String
  type          AppointmentEventType
  actorUserId   String?
  payload       Json
  createdAt     DateTime             @default(now())
  appointment   Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actorUser     User?                @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  channel   NotificationChannel
  template  String
  status    NotificationStatus @default(PENDING)
  payload   Json
  sentAt    DateTime?
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailLog {
  id             String       @id @default(cuid())
  businessId     String?
  userId         String?
  appointmentId  String?
  resendEmailId  String?
  template       String
  toEmail        String
  subject        String
  status         String
  errorMessage   String?
  createdAt      DateTime     @default(now())
  business       Business?    @relation(fields: [businessId], references: [id], onDelete: SetNull)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([userId])
  @@index([appointmentId])
}

model BillingCustomer {
  id               String   @id @default(cuid())
  businessId       String   @unique
  stripeCustomerId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BillingSubscription {
  id                  String   @id @default(cuid())
  businessId          String   @unique
  stripeSubscriptionId String
  stripePriceId       String
  status              String
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model PaymentRecord {
  id                      String        @id @default(cuid())
  businessId              String
  appointmentId           String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  amountCents             Int
  currency                String
  type                    PaymentType
  status                  PaymentStatus @default(PENDING)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  business                Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment             Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([appointmentId])
}

model WebhookEvent {
  id              String          @id @default(cuid())
  provider        WebhookProvider
  externalEventId String
  type            String
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@unique([provider, externalEventId])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String
  scope        String
  requestHash  String
  responseCode Int?
  responseBody Json?
  createdAt    DateTime @default(now())

  @@unique([scope, key])
}
